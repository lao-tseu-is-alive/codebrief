# codebrief – environment configuration sample
# Copy to .env and fill in values, or export variables directly in your shell.
# None of these are required at the same time — pick a provider and set what it needs.

# ── Provider ──────────────────────────────────────────────────────────────────
# Which embedding provider to use.
# Values: openai | ollama
# Auto-detected if unset: uses openai when OPENAI_API_KEY is present, else ollama.
LLM_PROVIDER=ollama

# ── Embedding model ───────────────────────────────────────────────────────────
# Model used to embed chunks during `index` and to embed the query during `query`.
# Provider-specific default is used when this is unset.
#   openai default : text-embedding-3-small
#   ollama default : nomic-embed-text
LLM_EMBEDDER_MODEL=nomic-embed-text

# ── Query / completion model (future) ─────────────────────────────────────────
# Reserved for a planned LLM-based answer step on top of retrieval results.
# Not used by the current version.
# LLM_QUERY_MODEL=llama3.2

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Ollama ────────────────────────────────────────────────────────────────────
# Base URL of a running Ollama instance. Defaults to http://localhost:11434.
OLLAMA_HOST=http://localhost:11434
